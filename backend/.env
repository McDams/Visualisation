# Database Configuration
# Supported: sqlite, postgresql
# SQLite: sqlite:///./sensor_data.db
# PostgreSQL: postgresql://user:password@localhost/sensor_db
DATABASE_URL=sqlite:///./sensor_data.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
SQL_ECHO=False
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1

# Environment
ENV=development
